---
import "@/styles/global.css";
import interLatinWoff2 from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import SEOHead from "@/components/seo/SEOHead.astro";
import Analytics from "@/components/Analytics.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { seoConfig } from "@/config/seo";

const lang = seoConfig.locale.split("_")[0];

interface Props {
  title: string;
  description: string;
  image?: string | undefined;
  canonicalUrl?: string | undefined;
  type?: "website" | "article" | undefined;
  publishedDate?: Date | undefined;
  updatedDate?: Date | undefined;
  authorName?: string | undefined;
  noindex?: boolean | undefined;
}

const { title, description, image, canonicalUrl, type, publishedDate, updatedDate, authorName, noindex } = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" href={interLatinWoff2} as="font" type="font/woff2" crossorigin />
    <SEOHead
      title={title}
      description={description}
      image={image}
      canonicalUrl={canonicalUrl}
      type={type}
      publishedDate={publishedDate}
      updatedDate={updatedDate}
      authorName={authorName}
      noindex={noindex}
    />
    <slot name="head" />
    <Analytics />
    <script is:inline>
      if (
        localStorage.getItem("theme") === "dark" ||
        (!localStorage.getItem("theme") &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class="flex min-h-screen flex-col font-sans antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
