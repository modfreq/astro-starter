---
import type { GetStaticPathsOptions } from "astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogPostCard from "@/components/blog/BlogPostCard.astro";
import Pagination from "@/components/blog/Pagination.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import { siteConfig } from "@/config/site";
import { breadcrumbSchema } from "@/components/seo/schemas";
import { resolveAuthor } from "@/lib/authors";
import type { ResolvedAuthor } from "@/lib/authors";

export const prerender = true;

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const PAGE_SIZE = 10;
  const posts = (await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  const authorIds = [...new Set(posts.map((p) => p.data.author))];
  const authors = await Promise.all(authorIds.map((id) => resolveAuthor(id)));
  const authorMap = new Map<string, ResolvedAuthor>(
    authorIds.map((id, i) => [id, authors[i]]),
  );

  return authorIds.flatMap((authorId) => {
    const filtered = posts.filter((p) => p.data.author === authorId);
    return paginate(filtered, {
      params: { author: authorId },
      props: { author: authorMap.get(authorId)! },
      pageSize: PAGE_SIZE,
    });
  });
}

const { author: authorParam } = Astro.params;
const { page, author } = Astro.props;
const title = page.currentPage === 1
  ? `Posts by ${author.name}`
  : `Posts by ${author.name} — Page ${page.currentPage}`;

const socialLinks = [
  { key: "github", url: author.social.github, label: "GitHub" },
  { key: "twitter", url: author.social.twitter, label: "Twitter" },
  { key: "linkedin", url: author.social.linkedin, label: "LinkedIn" },
  { key: "mastodon", url: author.social.mastodon, label: "Mastodon" },
  { key: "website", url: author.social.website, label: "Website" },
].filter((l) => l.url);
---

<BaseLayout title={title} description={`All posts by ${author.name}.`}>
  <Fragment slot="head">
    <JsonLd schema={breadcrumbSchema([
      { name: "Home", url: siteConfig.siteUrl },
      { name: "Blog", url: `${siteConfig.siteUrl}/blog/` },
      { name: author.name, url: `${siteConfig.siteUrl}/blog/author/${authorParam}/` },
    ])} />
    {page.url.prev && <link rel="prev" href={page.url.prev} />}
    {page.url.next && <link rel="next" href={page.url.next} />}
  </Fragment>
  <div class="mx-auto max-w-3xl px-4 py-16">
    <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground">&larr; Back to blog</a>
    <div class="mt-6 flex items-center gap-4">
      <Image
        src={author.avatar}
        alt={author.name}
        width={80}
        height={80}
        class="size-20 shrink-0 rounded-full"
      />
      <div>
        <h1 class="text-3xl font-bold">{author.name}</h1>
        {author.bio && (
          <p class="mt-1 text-muted-foreground">{author.bio}</p>
        )}
        {socialLinks.length > 0 && (
          <div class="mt-2 flex gap-2">
            {socialLinks.map(({ key, url, label }) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted-foreground transition-colors hover:text-foreground"
                aria-label={label}
              >
                {key === "github" && (
                  <svg class="size-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                )}
                {key === "twitter" && (
                  <svg class="size-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                )}
                {key === "linkedin" && (
                  <svg class="size-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"/></svg>
                )}
                {key === "mastodon" && (
                  <svg class="size-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054 19.648 19.648 0 0 0 4.636.536c.356 0 .711 0 1.068-.015 1.963-.062 4.032-.21 5.962-.672.048-.011.094-.027.138-.048 2.48-.55 4.84-2.27 5.079-6.79.009-.17.03-1.76.03-1.933 0-.59.22-4.186-.31-6.39z"/><path d="M19.903 7.515v5.675h-2.25V7.685c0-1.16-.49-1.75-1.47-1.75-1.083 0-1.625.7-1.625 2.082v3.015h-2.237V7.957c0-1.382-.542-2.082-1.625-2.082-.98 0-1.47.59-1.47 1.75v5.505h-2.25V7.515c0-1.16.295-2.082.89-2.766.611-.684 1.413-1.035 2.41-1.035 1.154 0 2.028.443 2.604 1.328l.561.942.561-.942C14.96 4.157 15.834 3.714 16.988 3.714c.997 0 1.799.351 2.41 1.035.595.684.89 1.606.89 2.766z"/></svg>
                )}
                {key === "website" && (
                  <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                )}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
    <div class="mt-8 flex flex-col gap-4">
      {page.data.map((post) => (
        <BlogPostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
          tags={post.data.tags}
          category={post.data.category}
          author={author}
        />
      ))}
    </div>
    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
    />
  </div>
</BaseLayout>
