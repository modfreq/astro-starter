---
import type { GetStaticPathsOptions } from "astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogPostCard from "@/components/blog/BlogPostCard.astro";
import Pagination from "@/components/blog/Pagination.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import { siteConfig } from "@/config/site";
import { breadcrumbSchema, personSchema } from "@/components/seo/schemas";
import { resolveAuthor } from "@/lib/authors";
import type { ResolvedAuthor } from "@/lib/authors";

export const prerender = true;

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const PAGE_SIZE = 10;
  const posts = (
    await getCollection("blog", ({ data }) => {
      return import.meta.env.PROD ? !data.draft : true;
    })
  ).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  const authorIds = [...new Set(posts.map((p) => p.data.author))];
  const authors = await Promise.all(authorIds.map((id) => resolveAuthor(id)));
  const authorMap = new Map<string, ResolvedAuthor>(
    authorIds.map((id, i) => [id, authors[i]]),
  );

  return authorIds.flatMap((authorId) => {
    const filtered = posts.filter((p) => p.data.author === authorId);
    return paginate(filtered, {
      params: { author: authorId },
      props: { author: authorMap.get(authorId)! },
      pageSize: PAGE_SIZE,
    });
  });
}

const { author: authorParam } = Astro.params;
const { page, author } = Astro.props;
const title =
  page.currentPage === 1
    ? `Posts by ${author.name}`
    : `Posts by ${author.name} — Page ${page.currentPage}`;

const authorUrl = `${siteConfig.siteUrl}/blog/author/${authorParam}/`;
const authorSameAs = [
  author.social.github,
  author.social.twitter,
  author.social.linkedin,
  author.social.mastodon,
  author.social.website,
].filter(Boolean);
---

<BaseLayout title={title} description={`All posts by ${author.name}.`}>
  <Fragment slot="head">
    <JsonLd
      schema={personSchema({
        name: author.name,
        url: authorUrl,
        description: author.bio || undefined,
        sameAs: authorSameAs,
      })}
    />
    <JsonLd
      schema={breadcrumbSchema([
        { name: "Home", url: siteConfig.siteUrl },
        { name: "Blog", url: `${siteConfig.siteUrl}/blog/` },
        { name: author.name, url: authorUrl },
      ])}
    />
    {page.url.prev && <link rel="prev" href={page.url.prev} />}
    {page.url.next && <link rel="next" href={page.url.next} />}
  </Fragment>
  <div class="mx-auto max-w-3xl px-4 py-16">
    <a href="/blog" class="text-muted-foreground hover:text-foreground text-sm"
      >&larr; Back to blog</a
    >
    <div class="mt-6 flex items-center gap-4">
      <Image
        src={author.avatar}
        alt={author.name}
        width={80}
        height={80}
        class="size-20 shrink-0 rounded-full"
      />
      <div>
        <h1 class="text-3xl font-bold">{author.name}</h1>
        {author.bio && <p class="text-muted-foreground mt-1">{author.bio}</p>}
        <SocialLinks
          social={author.social}
          iconClass="size-5"
          class="mt-2 flex gap-2"
        />
      </div>
    </div>
    <div class="mt-8 flex flex-col gap-4">
      {
        page.data.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            tags={post.data.tags}
            category={post.data.category}
            author={author}
          />
        ))
      }
    </div>
    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
    />
  </div>
</BaseLayout>
