---
import BaseLayout from "@/layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="mx-auto max-w-3xl px-4 py-16 text-center">
    <h1 class="text-4xl font-bold">404</h1>
    <p class="mt-4 text-lg text-muted-foreground">The page you're looking for doesn't exist.</p>
    <a href="/" class="mt-6 inline-block text-sm text-muted-foreground underline underline-offset-4 hover:text-foreground">Go home</a>
  </div>
</BaseLayout>
