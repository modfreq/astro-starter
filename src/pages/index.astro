---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Button } from "@/components/ui/button";
import JsonLd from "@/components/seo/JsonLd.astro";
import { siteConfig } from "@/config/site";
import { websiteSchema } from "@/components/seo/schemas";
---

<BaseLayout
  title={siteConfig.siteName}
  description={siteConfig.siteDescription}
>
  <Fragment slot="head">
    <JsonLd schema={websiteSchema(siteConfig)} />
  </Fragment>
  <div class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-4xl font-bold">Astro Starter</h1>
    <p class="text-muted-foreground mt-4 text-lg">
      Your new Astro project is ready.
    </p>
    <div class="mt-8 flex gap-4">
      <a href="/blog/getting-started/">
        <Button>Get Started</Button>
      </a>
      <a href="/blog/">
        <Button variant="outline">Read the Blog</Button>
      </a>
    </div>
  </div>
</BaseLayout>
