---
import { ModeToggle } from "@/components/ModeToggle";
import { seoConfig } from "@/config/seo";
---

<header class="border-b border-border">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3">
    <div class="flex items-center gap-6">
      <a href="/" class="text-sm font-semibold">{seoConfig.siteName}</a>
      <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground">Blog</a>
    </div>
    <ModeToggle client:load />
  </nav>
</header>
