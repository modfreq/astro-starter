---
import { ModeToggle } from "@/components/ModeToggle";
import { siteConfig } from "@/config/site";
---

<header class="border-b border-border">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3">
    <div class="flex items-center gap-6">
      <a href="/" class="text-sm font-semibold">{siteConfig.siteName}</a>
      {siteConfig.navigation.map((link) => (
        <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground">{link.label}</a>
      ))}
    </div>
    <ModeToggle client:load />
  </nav>
</header>
