---
import { siteConfig } from "@/config/site";
import SocialLinks from "@/components/SocialLinks.astro";
---

<footer class="border-border border-t">
  <div
    class="text-muted-foreground mx-auto flex max-w-3xl items-center justify-between px-4 py-6 text-sm"
  >
    <span>&copy; {new Date().getFullYear()} {siteConfig.siteName}</span>
    <div class="flex items-center gap-4">
      <SocialLinks social={siteConfig.social} class="flex items-center gap-4" />
      {
        siteConfig.footer.links.map((link) => (
          <a href={link.href} class="hover:text-foreground">
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
