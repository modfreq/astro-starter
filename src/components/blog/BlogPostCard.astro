---
import FormattedDate from "./FormattedDate.astro";
import AuthorByline from "./AuthorByline.astro";
import type { ResolvedAuthor } from "@/lib/authors";

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
  category?: string;
  author?: ResolvedAuthor;
}

const { title, description, date, slug, tags = [], category, author } = Astro.props;
---

<article class="group relative rounded-xl border border-border bg-card p-6 shadow-xs transition-colors hover:bg-accent">
  <div class="flex flex-col gap-2">
    <h2 class="text-lg font-medium group-hover:text-accent-foreground">
      <a href={`/blog/${slug}`} class="after:absolute after:inset-0">
        {title}
      </a>
    </h2>
    <p class="text-sm text-muted-foreground">{description}</p>
    <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      {author && (
        <>
          <AuthorByline author={author} />
          <span aria-hidden="true">&middot;</span>
        </>
      )}
      <FormattedDate date={date} />
      {category && (
        <>
          <span aria-hidden="true">&middot;</span>
          <a
            href={`/blog/category/${category.toLowerCase()}/`}
            class="relative z-10 text-primary hover:underline"
          >
            {category}
          </a>
        </>
      )}
      {tags.length > 0 && (
        <>
          <span aria-hidden="true">&middot;</span>
          <div class="flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <a
                href={`/blog/tag/${tag}/`}
                class="relative z-10 inline-flex h-5 items-center rounded-full border border-border px-2 text-xs font-medium text-foreground hover:bg-accent-foreground hover:text-accent"
              >
                {tag}
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </div>
</article>
