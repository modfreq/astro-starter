---
import { siteConfig } from "@/config/site";

interface Props {
  date: Date;
  class?: string;
}

const { date, class: className } = Astro.props;
const dateLocale = siteConfig.locale.replace("_", "-");
---

<time datetime={date.toISOString()} class={className}>
  {date.toLocaleDateString(dateLocale, {
    year: "numeric",
    month: "long",
    day: "numeric",
  })}
</time>
