---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 0 && (
  <details open class="mt-8 rounded-lg border border-border p-4">
    <summary class="cursor-pointer text-sm font-semibold">Table of Contents</summary>
    <nav class="mt-3">
      <ul class="space-y-1.5 text-sm">
        {filtered.map((h) => (
          <li class={h.depth === 3 ? "ml-4" : ""}>
            <a href={`#${h.slug}`} class="text-muted-foreground hover:text-foreground">
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </details>
)}
