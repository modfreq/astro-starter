---
import FormattedDate from "./FormattedDate.astro";
import AuthorByline from "./AuthorByline.astro";
import type { ResolvedAuthor } from "@/lib/authors";

interface Props {
  date: Date;
  readingTime: string;
  updatedDate?: Date | undefined;
  tags?: string[] | undefined;
  category?: string | undefined;
  author?: ResolvedAuthor;
}

const { date, readingTime, updatedDate, tags = [], category, author } = Astro.props;
---

<div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
  {author && (
    <>
      <AuthorByline author={author} />
      <span aria-hidden="true">&middot;</span>
    </>
  )}
  <FormattedDate date={date} />
  <span aria-hidden="true">&middot;</span>
  <span>{readingTime}</span>
  {category && (
    <>
      <span aria-hidden="true">&middot;</span>
      <a href={`/blog/category/${category.toLowerCase()}/`} class="text-primary hover:underline">
        {category}
      </a>
    </>
  )}
  {updatedDate && (
    <>
      <span aria-hidden="true">&middot;</span>
      <span>
        Updated <FormattedDate date={updatedDate} />
      </span>
    </>
  )}
</div>
{tags.length > 0 && (
  <div class="mt-2 flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <a
        href={`/blog/tag/${tag}/`}
        class="inline-flex h-5 items-center rounded-full border border-border px-2 text-xs font-medium text-foreground hover:bg-accent-foreground hover:text-accent"
      >
        {tag}
      </a>
    ))}
  </div>
)}
