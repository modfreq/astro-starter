---
import { Image } from "astro:assets";
import type { ResolvedAuthor } from "@/lib/authors";
import SocialLinks from "@/components/SocialLinks.astro";

interface Props {
  author: ResolvedAuthor;
}

const { author } = Astro.props;
---

<div class="border-border bg-card flex items-start gap-4 rounded-xl border p-6">
  <a href={`/blog/author/${author.id}/`} class="shrink-0">
    <Image
      src={author.avatar}
      alt={author.name}
      width={64}
      height={64}
      class="rounded-full"
    />
  </a>
  <div class="min-w-0">
    <a href={`/blog/author/${author.id}/`} class="font-medium hover:underline">
      {author.name}
    </a>
    {
      author.bio && (
        <p class="text-muted-foreground mt-1 line-clamp-2 text-sm">
          {author.bio}
        </p>
      )
    }
    <SocialLinks social={author.social} class="mt-2 flex gap-2" />
  </div>
</div>
