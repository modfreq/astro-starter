# Deployment adapter: "cloudflare" | "node" (default: cloudflare)
ADAPTER=cloudflare

# Site URL (required for sitemap/canonical URLs)
SITE_URL=https://example.com

# Analytics (optional — set one or neither)
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
